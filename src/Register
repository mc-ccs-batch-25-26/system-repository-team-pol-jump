<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CyberGuard Register</title>

<link rel="stylesheet" href="register.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body class="register-page">

<div class="register-card" id="authCard">

  <div class="register-logo">
    <i class="fa-solid fa-shield-halved"></i>
    <h2>Student Register</h2>
    <p>CyberGuard Reporting System</p>
  </div>

  <!-- INPUTS -->
  <div class="input-group">
    <label>Full Name</label>
    <input type="text" id="fullname" placeholder="Enter your full name">
  </div>

  <div class="input-group">
    <label>Username</label>
    <input type="text" id="username" placeholder="Choose a username">
  </div>

  <div class="input-group">
    <label>Password</label>
    <input type="password" id="password" placeholder="Enter password">
  </div>

  <div class="input-group">
    <label>Confirm Password</label>
    <input type="password" id="confirmPassword" placeholder="Confirm password">
  </div>

  <button class="register-btn" onclick="register()">Register</button>

  <p class="login-text">
    Already have an account? <a href="#" onclick="goToPage('login.html','left')">Login here</a>
  </p>

</div>

<script>

/* ===============================
   ✅ SAFE GET USERS
=============================== */
function getUsers(){
  try{
    let data = localStorage.getItem("users");
    return data ? JSON.parse(data) : [];
  }catch(e){
    console.log("Corrupted users data, resetting safely...");
    return [];
  }
}

/* ===============================
   ✅ SAVE USERS (WITH BACKUP)
=============================== */
function saveUsers(users){
  // 🔥 backup bago mag save
  localStorage.setItem("backup_users", localStorage.getItem("users"));
  localStorage.setItem("users", JSON.stringify(users));
}

/* ===============================
   REGISTER FUNCTION (SAFE)
=============================== */
function register(){
  let fullname = document.getElementById("fullname").value.trim();
  let username = document.getElementById("username").value.trim();
  let password = document.getElementById("password").value;
  let confirmPassword = document.getElementById("confirmPassword").value;

  if(!fullname || !username || !password){
    alert("Please fill all fields");
    return;
  }

  if(password !== confirmPassword){
    alert("Passwords do not match");
    return;
  }

  let users = getUsers();

  // 🔥 prevent duplicate username
  if(users.some(u => u.username === username)){
    alert("Username already exists");
    return;
  }

  // 🔥 CREATE REAL UNIQUE ACCOUNT
  let newUser = {
    id: "u_" + Date.now(),
    fullname,
    username,
    password,
    role: "student"
  };

  users.push(newUser);
  saveUsers(users);

  alert("Account created successfully!");

  goToPage("login.html", "left");
}

/* ===============================
   CARD ANIMATION
=============================== */

// ENTER
window.addEventListener("DOMContentLoaded", () => {
  const card = document.getElementById("authCard");
  if(card){
    card.classList.add("show");
  }
});

// NAVIGATION
function goToPage(page, direction = "right"){
  const card = document.getElementById("authCard");

  if(!card){
    window.location.href = page;
    return;
  }

  if(direction === "left"){
    card.classList.add("exit-left");
  } else {
    card.classList.add("exit-right");
  }

  setTimeout(() => {
    window.location.href = page;
  }, 350);
}

</script>

</body>
</html>

/* ===== BODY & BACKGROUND ===== */
body, html {
  margin: 0;
  padding: 0;
  height: 100%;
  font-family: 'Poppins', sans-serif;
}

.register-page {
  position: relative;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

/* Background image */
.register-page::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 120%;
  height: 120%;
  background: url('images/mchs.jpg') center/cover no-repeat;
  filter: blur(8px) brightness(0.6);
  transform: scale(1.1);
  animation: moveBackground 30s linear infinite alternate;
  z-index: -2;
}

/* Overlay */
.register-page::after {
  content: "";
  position: absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background: rgba(0,0,0,0.25);
  z-index:-1;
}

/* Background animation */
@keyframes moveBackground {
  0% { transform: translate(0,0) scale(1.1); }
  50% { transform: translate(-20px,-10px) scale(1.1); }
  100% { transform: translate(0,0) scale(1.1); }
}

/* ===== REGISTER CARD ===== */
.register-card {
  position: relative;
  background: rgba(255,255,255,0.9);
  padding: 40px;
  width: 350px;
  border-radius: 14px;
  box-shadow: 0 15px 40px rgba(0,0,0,0.25);
  z-index: 10;
  text-align: center;

  /* 🔥 ANIMATION */
  opacity: 1;
  transform: translateX(40px) scale(0.95);
  transition: all 0.4s ease;
}

/* ENTER */
.register-card.show {
  opacity: 1;
  transform: translateX(0) scale(1);
}

/* EXIT */
.register-card.exit-left {
  opacity: 0;
  transform: translateX(-60px) scale(0.9);
}

.register-card.exit-right {
  opacity: 0;
  transform: translateX(60px) scale(0.9);
}

/* ===== LOGO ===== */
.register-logo i {
  font-size: 40px;
  color: #4f46e5;
  margin-bottom: 10px;
}

.register-logo h2 {
  margin: 5px 0;
}

.register-logo p {
  font-size: 14px;
  color: #555;
}

/* ===== INPUTS ===== */
.input-group {
  margin-bottom: 18px;
  text-align: left;
}

.input-group label {
  font-size: 14px;
  display: block;
  margin-bottom: 6px;
}

.input-group input {
  width: 100%;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
  transition: 0.2s;
}

.input-group input:focus {
  outline: none;
  border-color: #4f46e5;
  box-shadow: 0 0 0 2px rgba(79,70,229,0.15);
}

/* ===== BUTTON ===== */
.register-btn {
  width: 100%;
  padding: 12px;
  border: none;
  background: #4f46e5;
  color: white;
  border-radius: 6px;
  font-size: 15px;
  cursor: pointer;
  margin-top: 10px;
  transition: 0.3s;
}

.register-btn:hover {
  background: #4338ca;
  transform: translateY(-2px);
}

/* ===== LOGIN TEXT ===== */
.login-text {
  text-align: center;
  margin-top: 15px;
  font-size: 14px;
}

.login-text a {
  color: #4f46e5;
  text-decoration: none;
  font-weight: 500;
}

/* ===== SMOOTH RENDER ===== */
* {
  backface-visibility: hidden;
  -webkit-font-smoothing: antialiased;
}
